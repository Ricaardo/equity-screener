# Live data source for the dashboard (path C). When set, the app fetches report
# JSON from this base at runtime instead of the static build snapshot, so the
# pipeline can refresh data without redeploying. Leave unset for local dev.
#
# Point it at the raw.githubusercontent.com path of the data-latest branch that
# scripts/publish_reports_branch.sh pushes to (raw serves with CORS: *).
VITE_DATA_BASE_URL=https://raw.githubusercontent.com/Ricaardo/ah-stock-screener/data-latest
